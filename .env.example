# Google Analytics 4 — set to your GA4 Measurement ID (starts with G-)
# Leave blank or remove to disable analytics in this build.
VITE_GA_MEASUREMENT_ID=

# ─────────────────────────────────────────────────────────────────────
# Callback form — SMTP settings for api/callback.js (server-side only)
# These are NOT exposed to the browser (no VITE_ prefix).
# Set these in Vercel → Settings → Environment Variables for production.
# ─────────────────────────────────────────────────────────────────────

# Provider examples:
#   Gmail:              SMTP_HOST=smtp.gmail.com    PORT=465  SECURE=true   (use App Password)
#   Zoho:               SMTP_HOST=smtp.zoho.in      PORT=465  SECURE=true
#   Resend:             SMTP_HOST=smtp.resend.com   PORT=465  SECURE=true   USER=resend  PASS=re_xxx
#   Brevo (Sendinblue): SMTP_HOST=smtp-relay.brevo.com PORT=587 SECURE=false
#   SendGrid:           SMTP_HOST=smtp.sendgrid.net PORT=587  SECURE=false  USER=apikey  PASS=SG.xxx

SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=

# "From" header on outgoing email. MUST be an address you're authorized to send as.
# Format: "Display Name <email@domain.com>"
SMTP_FROM="Slate Concept Studios <noreply@slateconcepts.com>"

# Where new lead notifications are sent. Comma-separate multiple recipients.
LEADS_TO=danish@slateconcepts.com

# (Optional) CC additional addresses on every lead notification.
LEADS_CC=
